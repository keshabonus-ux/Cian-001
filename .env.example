# Чат-бот (OpenRouter). Ключ попадёт в клиентский бандл — используй временный!
# Получить: https://openrouter.ai/keys
NEXT_PUBLIC_OPENROUTER_API_KEY=
# Любая модель с openrouter.ai, напр. google/gemma-3-27b-it:free, meta-llama/llama-3.1-8b-instruct:free
NEXT_PUBLIC_OPENROUTER_MODEL=z-ai/glm-4.5-air:free
